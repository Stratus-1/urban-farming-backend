ENVIRONMENT=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Phase 1: keep the current Supabase database while compute moves to Cloud Run.
DATA_BACKEND=supabase
AUTH_MODE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 2: point the same API at Cloud SQL PostgreSQL.
DATABASE_URL=postgresql+asyncpg://urban_farming:password@127.0.0.1:5432/urban_farming
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Phase 3: replace Supabase Auth with Identity Platform or another OIDC provider.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

STORAGE_BACKEND=supabase
GCS_BUCKET=
GCP_PROJECT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Urban Farming
ADMIN_EMAIL=admin@stratsol.co.za
GEOCODING_USER_AGENT=UrbanFarmingPlatform/1.0

