ENVIRONMENT=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Current setup: Cloud SQL PostgreSQL + backend-native auth (no Supabase).
# Tip: scripts/sync_frontend_env.py generates a local .env with these filled in.
DATA_BACKEND=postgres
AUTH_MODE=native
# Any long random string; generate with: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ISSUER=urban-farming-api
JWT_AUDIENCE=urban-farming
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
# GCP console -> APIs & Services -> Credentials -> OAuth client ID (web) — for POST /auth/google
GOOGLE_CLIENT_ID=

# Local: docker compose postgres. Cloud Run: unix socket, e.g.
# postgresql+asyncpg://USER:PASSWORD@/urban_farming?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://urban_farming:local-development-only@127.0.0.1:5432/urban_farming
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

STORAGE_BACKEND=gcs
GCS_BUCKET=
GCP_PROJECT_ID=

# Legacy Supabase mode (DATA_BACKEND=supabase / AUTH_MODE=supabase) — kept for rollback.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Alternative OIDC auth (AUTH_MODE=oidc), e.g. GCP Identity Platform.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# The email gateway uses STARTTLS, so Gmail must be on 587 (not 465/SSL).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Urban Farming
ADMIN_EMAIL=admin@stratsol.co.za
# Nominatim asks for an identifying UA with contact info.
GEOCODING_USER_AGENT=UrbanFarmingPlatform/1.0 (admin@stratsol.co.za)
